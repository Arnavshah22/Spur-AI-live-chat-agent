# Database (PostgreSQL via Docker Compose for local, Neon for production)
DATABASE_URL=postgresql://spur:spurdev123@localhost:5432/spur_chat

# LLM API (Using Groq - free alternative to OpenAI)
OPENAI_API_KEY=your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Server
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Limits
MAX_MESSAGE_LENGTH=2000
MAX_HISTORY_MESSAGES=10
MAX_TOKENS=500
LLM_TIMEOUT_MS=30000

# Redis Cache (Optional - improves performance by caching LLM responses)
# For local: redis://localhost:6379 (requires Docker Compose)
# For production: rediss://default:PASSWORD@HOST.upstash.io:6379 (Upstash Redis)
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=86400

# Push Notifications (VAPID keys for Web Push)
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your-email@example.com
