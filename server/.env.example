NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://spur:spurdev123@localhost:5432/spur_chat

# LLM Configuration
# Option 1: Groq (Free, recommended for testing)
OPENAI_API_KEY=gsk_your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Option 2: OpenAI (Requires credits - uncomment and remove OPENAI_BASE_URL above)
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

MAX_MESSAGE_LENGTH=2000
MAX_HISTORY_MESSAGES=10
MAX_TOKENS=500
LLM_TIMEOUT_MS=30000
CORS_ORIGIN=http://localhost:5173

# Redis Cache (optional — app works without it)
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=86400
